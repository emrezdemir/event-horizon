{
  "expo": {
    "name": "Haberlerim",
    "slug": "news-app",
    "scheme": "haberlerim",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.newsapp",
      "infoPlist": {
        "UIBackgroundModes": ["fetch", "processing"],
        "BGTaskSchedulerPermittedIdentifiers": [
          "com.example.newsapp.refresh"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.example.newsapp",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-background-fetch",
      "expo-notifications",
      [
        "expo-sqlite",
        {
          "useSQLCipher": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
